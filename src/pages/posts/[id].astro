---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES, withBase, formatDate } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const categoryLabel = CATEGORIES[post.data.category as keyof typeof CATEGORIES];

const hero = post.data.heroImage;
const heroSrc = hero ? (hero.startsWith('http') ? hero : withBase(hero)) : undefined;
// SVGはSNSのOGP画像として非対応のため除外
const ogImage = heroSrc && !heroSrc.endsWith('.svg') ? new URL(heroSrc, Astro.site).href : undefined;

// SNS埋め込み（blockquote）が本文にある場合だけ各公式スクリプトを読み込む
const body = post.body ?? '';
const hasTwitterEmbed = body.includes('twitter-tweet');
const hasInstagramEmbed = body.includes('instagram-media');
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentCategory={post.data.category}
  image={ogImage}
>
  <article class="article">
    <a class="category-badge" href={withBase(`/category/${post.data.category}/`)}>
      {categoryLabel}
    </a>
    <h1 class="article-title">{post.data.title}</h1>
    <p class="article-meta">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      公開
    </p>

    {
      heroSrc && (
        <figure class="article-hero">
          <img src={heroSrc} alt={post.data.heroImageAlt ?? post.data.title} />
          {post.data.heroImageCredit && <figcaption>{post.data.heroImageCredit}</figcaption>}
        </figure>
      )
    }

    <div class="article-body">
      <Content />
    </div>

    <!-- ad slot: article-bottom -->

    {
      post.data.tags.length > 0 && (
        <div class="tag-list">
          {post.data.tags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </div>
      )
    }

    <aside class="article-sources">
      <h2>出典・参考</h2>
      <ul>
        {
          post.data.sources.map((url) => (
            <li>
              <a href={url} target="_blank" rel="noopener noreferrer">
                {url}
              </a>
            </li>
          ))
        }
      </ul>
      <p>掲載内容は記事公開時点の情報です。最新の情報は各公式サイト等でご確認ください。</p>
    </aside>
  </article>

  {hasTwitterEmbed && <script async src="https://platform.twitter.com/widgets.js" is:inline></script>}
  {hasInstagramEmbed && <script async src="https://www.instagram.com/embed.js" is:inline></script>}
</BaseLayout>
