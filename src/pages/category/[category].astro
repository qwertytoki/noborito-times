---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../consts';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const label = CATEGORIES[category as keyof typeof CATEGORIES];
const posts = (await getCollection('posts', (post) => post.data.category === category)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={`${label}の記事一覧`} currentCategory={category}>
  <h2 class="page-heading">{label}の記事</h2>
  {
    posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </ul>
    ) : (
      <p class="prose">このカテゴリの記事はまだありません。</p>
    )
  }
</BaseLayout>
